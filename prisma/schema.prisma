generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  CUSTOMER
}

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  EMAIL
  PHONE
  DATE
  DROPDOWN
  RADIO
  CHECKBOX
  COLOR_PICKER
  IMAGE_UPLOAD
  FILE_UPLOAD
  QUANTITY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  icon        String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@index([slug])
  @@index([isActive])
}

// ─── Product ──────────────────────────────────────────────────────────────────

model Product {
  id           String   @id @default(cuid())
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  name         String
  slug         String   @unique
  description  String?
  basePrice    Decimal  @db.Decimal(10, 2)
  images       String[]
  isActive     Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  sortOrder    Int      @default(0)
  deliveryDays Int      @default(5)
  // Where customization text/photo appears on the live preview
  previewPosition String @default("center")
  // Customizer feature toggles (drag, textSize, photoZoom, whatsappBadge) — admin on/off
  features        Json?
  // ── WooCommerce-style optional features (null/false = feature removed) ──
  salePrice        Decimal? @db.Decimal(10, 2)
  discountPct      Int?
  manageStock      Boolean  @default(false)
  stockQty         Int?
  stockStatus      String   @default("IN_STOCK") // IN_STOCK | OUT_OF_STOCK | ON_BACKORDER
  soldIndividually Boolean  @default(false)
  shippingClass    String?  // "free" | "flat"
  shippingCost     Decimal? @db.Decimal(10, 2)
  codAvailable     Boolean  @default(true)
  weightGrams      Int?
  lengthIn         Float?
  widthIn          Float?
  heightIn         Float?
  noReturnPolicy   Boolean  @default(false)
  // Product attributes: [{ name: "Size", values: ["S","M","L"] }] — size/quality/colour/custom
  attributes       Json?
  // Admin checkbox: off = customer page pe "Customize Your Order" nahi dikhega
  customizeEnabled Boolean  @default(true)
  // Variable product: attribute-combination-wise price/stock/image.
  // null = simple product (purana behavior, no disturbance).
  // [{ id, attrs: {Size:"M",Colour:"Red"}, price, salePrice?, stockStatus?, image? }]
  variations       Json?
  // Ready-made sample design images shown to customer for inspiration
  sampleDesigns   String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fields         ProductField[]
  orderItems     OrderItem[]
  frameTemplates FrameTemplate[]
  reviews        ProductReview[]

  @@index([categoryId])
  @@index([slug])
  @@index([isActive])
}

// ─── Product Reviews ──────────────────────────────────────────────────────────

model ProductReview {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  rating    Int      // 1-5
  text      String?
  images    String[] @default([])
  videoUrl  String?
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([approved])
}

// ─── Frame Designer Templates ─────────────────────────────────────────────────
// Admin-designed product templates: draggable image/text/frame elements on a canvas.
// elements JSON: [{ id, type: "image"|"text"|"frame", label, x, y, w, h (percent),
//   radius, rotation, z, text?, fontFamily?, fontSize?, fontWeight?, align?, color?,
//   shape?, fill? }]

model FrameTemplate {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  elements  Json     @default("[]")
  bgImage   String?
  // Customer-facing options: allowed frame colors, text colors, fonts (incl.
  // admin-added Google fonts), fixed text sizes + defaults for each
  options   Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

// ─── Dynamic Field System ─────────────────────────────────────────────────────
// Admin creates fields per product — no code change needed to add new products

model ProductField {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  label       String
  fieldKey    String
  type        FieldType
  placeholder String?
  helpText    String?
  isRequired  Boolean   @default(true)
  sortOrder   Int       @default(0)
  // For IMAGE_UPLOAD: how many photos customer can upload (watch = multiple)
  maxFiles    Int       @default(1)
  options     FieldOption[]

  @@unique([productId, fieldKey])
  @@index([productId])
}

model FieldOption {
  id       String       @id @default(cuid())
  fieldId  String
  field    ProductField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  label    String
  value    String
  price    Decimal?     @db.Decimal(10, 2)
  sortOrder Int         @default(0)

  @@index([fieldId])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String    @unique
  passwordHash  String?
  image         String?
  emailVerified DateTime?
  role          Role      @default(CUSTOMER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders Order[]

  // DIVA relations
  divaProfile             DivaProfile?
  divaKYC                 DivaKYCSubmission?
  divaEmailTokens         DivaEmailVerifyToken[]
  divaPasswordTokens      DivaPasswordResetToken[]
  divaLoginHistory        DivaLoginHistory[]
  divaDevices             DivaDevice[]
  divaTwoFactor           DivaTwoFactorAuth?
  divaPortfolio           DivaPortfolio?
  divaDeposits            DivaDeposit[]
  divaDepositsReviewed    DivaDeposit[]            @relation("DivaDepositReviewer")
  divaWalletsCreated      DivaDepositWallet[]      @relation("DivaWalletCreator")
  divaLedgerEntries       DivaLedgerEntry[]        @relation("DivaLedgerCreator")
  divaWithdrawals         DivaWithdrawal[]         @relation("DivaUserWithdrawals")
  divaWithdrawalsReviewed DivaWithdrawal[]         @relation("DivaWithdrawalReviewer")
  divaReferralsGiven      DivaReferral[]           @relation("DivaReferrer")
  divaReferralReceived    DivaReferral?            @relation("DivaReferred")
  divaNotifications       DivaNotification[]
  divaAuditLogs           DivaAuditLog[]           @relation("DivaAuditActor")
  divaBalanceAdjustments  DivaBalanceAdjustment[]  @relation("DivaAdjCreator")
  divaUserRewards         DivaUserReward[]
  divaUserAchievements    DivaUserAchievement[]
  divaAnnouncements       DivaAnnouncement[]       @relation("DivaAnnouncementAuthor")
  divaAnnouncementBookmarks DivaAnnouncementBookmark[]
  divaRewardRules         DivaRewardRule[]         @relation("DivaRewardRuleCreator")
  divaGeneratedReports    DivaGeneratedReport[]    @relation("DivaReportGenerator")
  divaAlertsAssigned      DivaSystemAlert[]        @relation("DivaAlertAssignee")
  divaAlertsAcknowledged  DivaSystemAlert[]        @relation("DivaAlertAcknowledger")

  @@index([phone])
  @@index([email])
}

// ─── OTP ──────────────────────────────────────────────────────────────────────

model OtpToken {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([phone])
}

// ─── Order ────────────────────────────────────────────────────────────────────

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  customerName  String
  customerPhone String
  customerEmail String?
  address       String
  city          String
  state         String
  pinCode       String
  subtotal      Decimal       @db.Decimal(10, 2)
  shippingCharge Decimal      @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal       @db.Decimal(10, 2)
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  razorpayOrderId String?
  razorpayPaymentId String?
  giftWrapping  Boolean       @default(false)
  giftMessage   String?
  deliveryDate  DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items OrderItem[]

  @@index([orderNumber])
  @@index([customerPhone])
  @@index([status])
  @@index([createdAt])
}

// ─── Order Item ───────────────────────────────────────────────────────────────

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  productName     String
  quantity        Int      @default(1)
  unitPrice       Decimal  @db.Decimal(10, 2)
  totalPrice      Decimal  @db.Decimal(10, 2)
  customizationData Json
  uploadedFiles   String[]
  createdAt       DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

// ─── Uploaded Files ───────────────────────────────────────────────────────────

model UploadedFile {
  id          String   @id @default(cuid())
  url         String
  publicId    String
  fileName    String?
  fileSize    Int?
  mimeType    String?
  uploadedAt  DateTime @default(now())
}

// ─── Settings ─────────────────────────────────────────────────────────────────

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@index([key])
}

// ══════════════════════════════════════════════════════════════════════════════
// DIVA GROWTH CAPITAL — separate fintech module (do NOT mix with BMW/OTG)
// ══════════════════════════════════════════════════════════════════════════════

// ─── DIVA Enums ───────────────────────────────────────────────────────────────

enum DivaAccountStatus {
  ACTIVE
  SUSPENDED
  FROZEN
  CLOSED
  PENDING_VERIFICATION
}

enum DivaKYCStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum DivaDocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVING_LICENSE
  SELFIE
}

enum DivaLoginStatus {
  SUCCESS
  FAILED
  BLOCKED
}

enum DivaPortfolioStatus {
  ACTIVE
  FROZEN
  SUSPENDED
  CLOSED
}

enum DivaLedgerType {
  DEPOSIT_CREDIT
  ADMIN_CREDIT
  ADMIN_DEBIT
  BALANCE_CORRECTION
  SYSTEM_ADJUSTMENT
}

enum DivaPortfolioEventType {
  PORTFOLIO_CREATED
  DEPOSIT_CREDITED
  WITHDRAWAL_DEBITED
  ADMIN_CREDIT
  ADMIN_DEBIT
  BALANCE_CORRECTION
  SYSTEM_ADJUSTMENT
  STATUS_CHANGED
}

enum DivaDepositStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum DivaWithdrawalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum DivaWithdrawalNetwork {
  TRC20
  ERC20
  BEP20
  BTC
  SOL
}

enum DivaFinancialOpsAction {
  WITHDRAWAL_SUBMITTED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  WITHDRAWAL_CANCELLED
  WITHDRAWAL_COMPLETED
  BALANCE_LOCKED
  BALANCE_UNLOCKED
  STATUS_CHANGED
}

enum DivaAuditAction {
  USER_REGISTERED
  USER_LOGIN
  USER_LOGOUT
  KYC_SUBMITTED
  KYC_APPROVED
  KYC_REJECTED
  DEPOSIT_SUBMITTED
  DEPOSIT_APPROVED
  DEPOSIT_REJECTED
  WITHDRAWAL_SUBMITTED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  BALANCE_ADJUSTED
  ADMIN_ACTION
  WALLET_CREATED
  WALLET_UPDATED
  WALLET_ACTIVATED
  WALLET_DEACTIVATED
  WALLET_DELETED
}

// ─── DIVA Profile ─────────────────────────────────────────────────────────────

model DivaProfile {
  id            String             @id @default(cuid())
  userId        String             @unique
  user          User               @relation(fields: [userId], references: [id])
  country       String?
  dateOfBirth   String?
  nationality   String?
  address       String?
  city          String?
  state         String?
  postalCode    String?
  walletAddress String?
  referralCode        String?            @unique
  referredBy          String?
  accountStatus       DivaAccountStatus  @default(PENDING_VERIFICATION)
  onboardingCompleted Boolean            @default(false)
  onboardingStep      Int                @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

// ─── DIVA Auth Tokens ─────────────────────────────────────────────────────────

model DivaEmailVerifyToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model DivaPasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

// ─── DIVA KYC ─────────────────────────────────────────────────────────────────

model DivaKYCSubmission {
  id          String          @id @default(cuid())
  userId      String          @unique
  user        User            @relation(fields: [userId], references: [id])
  status      DivaKYCStatus   @default(PENDING)
  fullName    String?
  dateOfBirth String?
  nationality String?
  address     String?
  adminNotes  String?
  reviewedBy  String?
  reviewedAt  DateTime?
  submittedAt DateTime?
  updatedAt   DateTime        @updatedAt

  documents   DivaKYCDocument[]

  @@index([status])
  @@index([userId])
}

model DivaKYCDocument {
  id         String           @id @default(cuid())
  kycId      String
  kyc        DivaKYCSubmission @relation(fields: [kycId], references: [id], onDelete: Cascade)
  type       DivaDocumentType
  url        String
  fileName   String?
  fileSize   Int?
  mimeType   String?
  uploadedAt DateTime         @default(now())

  @@index([kycId])
}

// ─── DIVA Login / Devices ─────────────────────────────────────────────────────

model DivaLoginHistory {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  ipAddress String?
  userAgent String?
  device    String?
  location  String?
  status    DivaLoginStatus @default(SUCCESS)
  createdAt DateTime        @default(now())

  @@index([userId])
  @@index([createdAt])
}

model DivaDevice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  deviceId    String?
  fingerprint String?
  userAgent   String?
  deviceName  String?
  lastSeen    DateTime @default(now())
  isTrusted   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model DivaTwoFactorAuth {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  secret      String
  isEnabled   Boolean  @default(false)
  backupCodes String[]
  enabledAt   DateTime?
}

// ─── DIVA Referrals ───────────────────────────────────────────────────────────

model DivaReferral {
  id              String              @id @default(cuid())
  referrerId      String
  referrer        User                @relation("DivaReferrer", fields: [referrerId], references: [id])
  referredId      String              @unique
  referred        User                @relation("DivaReferred", fields: [referredId], references: [id])
  referralCode    String?
  status          DivaReferralStatus  @default(PENDING)
  clickedAt       DateTime?
  registeredAt    DateTime?
  kycCompletedAt  DateTime?
  activatedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  events DivaReferralEvent[]

  @@index([referrerId])
  @@index([referralCode])
  @@index([status])
}

// ─── DIVA Portfolio ───────────────────────────────────────────────────────────

model DivaPortfolio {
  id               String              @id @default(cuid())
  userId           String              @unique
  user             User                @relation(fields: [userId], references: [id])
  currentBalance   Decimal             @default(0) @db.Decimal(24, 8)
  availableBalance Decimal             @default(0) @db.Decimal(24, 8)
  lockedBalance    Decimal             @default(0) @db.Decimal(24, 8)
  status           DivaPortfolioStatus @default(ACTIVE)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  ledgerEntries DivaLedgerEntry[]
  events        DivaPortfolioEvent[]
  adjustments   DivaBalanceAdjustment[]

  @@index([userId])
  @@index([status])
}

model DivaLedgerEntry {
  id              String         @id @default(cuid())
  portfolioId     String
  portfolio       DivaPortfolio  @relation(fields: [portfolioId], references: [id])
  userId          String
  transactionType DivaLedgerType
  amount          Decimal        @db.Decimal(24, 8)
  previousBalance Decimal        @db.Decimal(24, 8)
  newBalance      Decimal        @db.Decimal(24, 8)
  referenceType   String?
  referenceId     String?
  notes           String?
  createdBy       String?
  creator         User?          @relation("DivaLedgerCreator", fields: [createdBy], references: [id])
  createdAt       DateTime       @default(now())

  @@index([portfolioId])
  @@index([userId])
  @@index([createdAt])
}

model DivaPortfolioEvent {
  id               String                 @id @default(cuid())
  portfolioId      String
  portfolio        DivaPortfolio          @relation(fields: [portfolioId], references: [id])
  userId           String
  eventType        DivaPortfolioEventType
  eventDescription String?
  metadata         Json?
  createdAt        DateTime               @default(now())

  @@index([portfolioId])
  @@index([userId])
}

model DivaBalanceAdjustment {
  id             String        @id @default(cuid())
  portfolioId    String?
  portfolio      DivaPortfolio? @relation(fields: [portfolioId], references: [id])
  userId         String
  adjustmentType String
  amount         Decimal       @db.Decimal(24, 8)
  reason         String?
  ledgerEntryId  String?
  createdBy      String?
  creator        User?         @relation("DivaAdjCreator", fields: [createdBy], references: [id])
  createdAt      DateTime      @default(now())

  @@index([userId])
}

// ─── DIVA Deposits ────────────────────────────────────────────────────────────

model DivaDepositWallet {
  id           String    @id @default(cuid())
  walletName   String
  coinType     String
  network      String
  address      String
  qrImageUrl   String?
  instructions String?
  sortOrder    Int       @default(0)
  status       String    @default("ACTIVE")
  createdBy    String?
  creator      User?     @relation("DivaWalletCreator", fields: [createdBy], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  deposits DivaDeposit[]

  @@index([status])
}

model DivaDeposit {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  walletId        String
  wallet          DivaDepositWallet @relation(fields: [walletId], references: [id])
  coinType        String
  network         String
  amount          Decimal           @db.Decimal(20, 8)
  transactionHash String            @unique
  proofImageUrl   String?
  notes           String?
  status          DivaDepositStatus @default(PENDING)
  adminNotes      String?
  reviewedBy      String?
  reviewer        User?             @relation("DivaDepositReviewer", fields: [reviewedBy], references: [id])
  ledgerEntryId   String?
  submittedAt     DateTime          @default(now())
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([status])
  @@index([transactionHash])
}

// ─── DIVA Withdrawals ─────────────────────────────────────────────────────────

model DivaWithdrawal {
  id            String                @id @default(cuid())
  userId        String
  user          User                  @relation("DivaUserWithdrawals", fields: [userId], references: [id])
  amount        Decimal               @db.Decimal(24, 8)
  walletAddress String
  network       DivaWithdrawalNetwork @default(TRC20)
  status        DivaWithdrawalStatus  @default(SUBMITTED)
  userNotes     String?
  adminNotes    String?
  reviewedBy    String?
  reviewer      User?                 @relation("DivaWithdrawalReviewer", fields: [reviewedBy], references: [id])
  ledgerEntryId String?
  submittedAt   DateTime              @default(now())
  reviewedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  statusHistory DivaWithdrawalStatusHistory[]

  @@index([userId])
  @@index([status])
}

model DivaWithdrawalStatusHistory {
  id           String                @id @default(cuid())
  withdrawalId String
  withdrawal   DivaWithdrawal        @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)
  oldStatus    DivaWithdrawalStatus?
  newStatus    DivaWithdrawalStatus
  changedBy    String?
  notes        String?
  createdAt    DateTime              @default(now())

  @@index([withdrawalId])
}

// ─── DIVA Financial Ops Log ───────────────────────────────────────────────────

model DivaFinancialOpsLog {
  id          String                 @id @default(cuid())
  actionType  DivaFinancialOpsAction
  referenceId String?
  userId      String?
  performedBy String?
  ipAddress   String?
  metadata    Json?
  createdAt   DateTime               @default(now())

  @@index([actionType])
  @@index([userId])
  @@index([createdAt])
}

// ─── DIVA Notifications ───────────────────────────────────────────────────────

model DivaNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

// ─── DIVA Audit Log ───────────────────────────────────────────────────────────

model DivaAuditLog {
  id          String          @id @default(cuid())
  action      DivaAuditAction
  entityType  String
  entityId    String?
  performedBy String?
  actor       User?           @relation("DivaAuditActor", fields: [performedBy], references: [id])
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime        @default(now())

  @@index([action])
  @@index([performedBy])
  @@index([createdAt])
}

// ─── DIVA Forecasting ─────────────────────────────────────────────────────────

enum DivaContributionFreq {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum DivaCompoundingFreq {
  DAILY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model DivaForecastScenario {
  id                 String               @id @default(cuid())
  userId             String
  scenarioName       String
  initialAmount      Float
  contributionAmount Float
  contributionFreq   DivaContributionFreq @default(MONTHLY)
  durationYears      Int
  growthRate         Float
  compoundingFreq    DivaCompoundingFreq  @default(MONTHLY)
  color              String               @default("#D4AF37")
  isPinned           Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  results DivaForecastResult[]

  @@index([userId])
}

model DivaForecastResult {
  id              String               @id @default(cuid())
  scenarioId      String
  scenario        DivaForecastScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  projectedValue  Float
  totalContribs   Float
  estimatedGrowth Float
  dataPoints      Json
  generatedAt     DateTime             @default(now())

  @@index([scenarioId])
}

enum DivaMilestoneStatus {
  IN_PROGRESS
  ACHIEVED
  MISSED
  CANCELLED
}

model DivaUserMilestone {
  id            String              @id @default(cuid())
  userId        String
  milestoneName String
  title         String?
  targetAmount  Float
  currentAmount Float               @default(0)
  targetDate    DateTime?
  notes         String?
  status        DivaMilestoneStatus @default(IN_PROGRESS)
  isCompleted   Boolean             @default(false)
  completedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId])
}

// ─── DIVA Phase 6 — Referral & Community ──────────────────────────────────────

enum DivaReferralStatus {
  PENDING
  CLICKED
  REGISTERED
  KYC_COMPLETED
  ACTIVATED
  EXPIRED
}

enum DivaReferralEventType {
  LINK_GENERATED
  LINK_CLICKED
  ACCOUNT_CREATED
  KYC_SUBMITTED
  KYC_APPROVED
  ACTIVATED
}

enum DivaRewardType {
  POINTS
  BADGE
  CREDIT
  TIER_ADVANCEMENT
}

enum DivaRewardStatus {
  PENDING
  ACTIVE
  CLAIMED
  EXPIRED
}

enum DivaAnnouncementCategory {
  UPDATES
  EVENTS
  EDUCATION
  GENERAL
}

enum DivaAnnouncementStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum DivaAchievementTrigger {
  PROFILE_COMPLETED
  KYC_APPROVED
  FIRST_DEPOSIT
  FIRST_REFERRAL
  FIVE_REFERRALS
  TEN_REFERRALS
  COMMUNITY_ACTIVE
  DEPOSIT_MILESTONE
  REFERRAL_MILESTONE
}

// Extend DivaReferral with journey tracking fields
model DivaReferralEvent {
  id          String                @id @default(cuid())
  referralId  String
  referral    DivaReferral          @relation(fields: [referralId], references: [id], onDelete: Cascade)
  eventType   DivaReferralEventType
  metadata    Json?
  createdAt   DateTime              @default(now())

  @@index([referralId])
  @@index([eventType])
}

model DivaRewardRule {
  id           String         @id @default(cuid())
  ruleName     String
  description  String?
  rewardType   DivaRewardType
  rewardValue  Float
  triggerEvent String
  conditions   Json?
  isActive     Boolean        @default(true)
  createdBy    String?
  creator      User?          @relation("DivaRewardRuleCreator", fields: [createdBy], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  userRewards DivaUserReward[]

  @@index([isActive])
}

model DivaUserReward {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  ruleId      String?
  rule        DivaRewardRule?  @relation(fields: [ruleId], references: [id])
  rewardType  DivaRewardType
  rewardName  String
  rewardValue Float            @default(0)
  status      DivaRewardStatus @default(ACTIVE)
  awardedAt   DateTime         @default(now())
  claimedAt   DateTime?
  expiresAt   DateTime?

  @@index([userId])
  @@index([status])
}

model DivaAnnouncement {
  id          String                   @id @default(cuid())
  title       String
  content     String
  category    DivaAnnouncementCategory @default(GENERAL)
  status      DivaAnnouncementStatus   @default(DRAFT)
  isPinned    Boolean                  @default(false)
  imageUrl    String?
  publishedAt DateTime?
  scheduledAt DateTime?
  createdBy   String?
  author      User?                    @relation("DivaAnnouncementAuthor", fields: [createdBy], references: [id])
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  bookmarks DivaAnnouncementBookmark[]

  @@index([status])
  @@index([category])
  @@index([isPinned])
}

model DivaAnnouncementBookmark {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  announcementId String
  announcement   DivaAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@unique([userId, announcementId])
  @@index([userId])
}

model DivaAchievement {
  id          String                 @id @default(cuid())
  name        String
  description String
  badgeIcon   String                 @default("🏆")
  badgeColor  String                 @default("#D4AF37")
  trigger     DivaAchievementTrigger
  isActive    Boolean                @default(true)
  sortOrder   Int                    @default(0)
  createdAt   DateTime               @default(now())

  userAchievements DivaUserAchievement[]

  @@index([trigger])
  @@index([isActive])
}

model DivaUserAchievement {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  achievementId String
  achievement   DivaAchievement @relation(fields: [achievementId], references: [id])
  earnedAt      DateTime        @default(now())
  metadata      Json?

  @@unique([userId, achievementId])
  @@index([userId])
}

model DivaReferralClick {
  id           String   @id @default(cuid())
  referralCode String
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([referralCode])
}

// ─── DIVA Phase 7 — Analytics & BI ───────────────────────────────────────────

enum DivaSnapshotPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum DivaAlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum DivaAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum DivaReportFormat {
  CSV
  JSON
}

enum DivaReportStatus {
  PENDING
  COMPLETED
  FAILED
}

model DivaAnalyticsSnapshot {
  id                   String              @id @default(cuid())
  period               DivaSnapshotPeriod
  periodDate           DateTime
  totalUsers           Int                 @default(0)
  newUsers             Int                 @default(0)
  verifiedUsers        Int                 @default(0)
  activePortfolios     Int                 @default(0)
  totalDepositVolume   Decimal             @default(0) @db.Decimal(24, 8)
  totalWithdrawVolume  Decimal             @default(0) @db.Decimal(24, 8)
  depositCount         Int                 @default(0)
  withdrawCount        Int                 @default(0)
  kycApprovals         Int                 @default(0)
  kycRejections        Int                 @default(0)
  newReferrals         Int                 @default(0)
  activatedReferrals   Int                 @default(0)
  totalPortfolioValue  Decimal             @default(0) @db.Decimal(24, 8)
  metadata             Json?
  createdAt            DateTime            @default(now())

  @@unique([period, periodDate])
  @@index([period])
  @@index([periodDate])
}

model DivaKpiDefinition {
  id           String    @id @default(cuid())
  name         String
  description  String?
  formula      String
  unit         String    @default("number")
  target       Float?
  warningAt    Float?
  criticalAt   Float?
  isActive     Boolean   @default(true)
  sortOrder    Int       @default(0)
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  values DivaKpiValue[]

  @@index([isActive])
}

model DivaKpiValue {
  id        String           @id @default(cuid())
  kpiId     String
  kpi       DivaKpiDefinition @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  value     Float
  period    DivaSnapshotPeriod
  periodDate DateTime
  createdAt DateTime         @default(now())

  @@unique([kpiId, period, periodDate])
  @@index([kpiId])
  @@index([periodDate])
}

model DivaGeneratedReport {
  id          String           @id @default(cuid())
  reportName  String
  reportType  String
  format      DivaReportFormat @default(CSV)
  status      DivaReportStatus @default(PENDING)
  fileUrl     String?
  fileSize    Int?
  parameters  Json?
  generatedBy String?
  generator   User?            @relation("DivaReportGenerator", fields: [generatedBy], references: [id])
  rowCount    Int?
  errorMsg    String?
  createdAt   DateTime         @default(now())
  completedAt DateTime?

  @@index([reportType])
  @@index([generatedBy])
  @@index([createdAt])
}

model DivaSystemAlert {
  id          String            @id @default(cuid())
  title       String
  message     String
  severity    DivaAlertSeverity @default(INFO)
  status      DivaAlertStatus   @default(OPEN)
  alertType   String
  entityType  String?
  entityId    String?
  metadata    Json?
  assignedTo  String?
  assignee    User?             @relation("DivaAlertAssignee", fields: [assignedTo], references: [id])
  acknowledgedBy String?
  acknowledger   User?          @relation("DivaAlertAcknowledger", fields: [acknowledgedBy], references: [id])
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  createdAt      DateTime       @default(now())

  @@index([status])
  @@index([severity])
  @@index([alertType])
  @@index([createdAt])
}
